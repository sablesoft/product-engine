#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "support/terminal_image_link"

def usage
  <<~TEXT
    Usage:
      ruby scripts/image-link --path /absolute/or/relative/image.png
  TEXT
end

path = nil
argv = ARGV.dup

until argv.empty?
  flag = argv.shift
  case flag
  when "--path" then path = argv.shift
  when "-h", "--help"
    puts usage
    exit 0
  else
    warn "Unknown option: #{flag}\n\n#{usage}"
    exit 64
  end
end

if path.nil? || path.empty?
  warn "Missing required option --path\n\n#{usage}"
  exit 64
end

puts TerminalImageLink.preview_lines(path: path)
